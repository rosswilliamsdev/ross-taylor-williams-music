---
import PressCard from './PressCard.astro'
import type { PressQuote } from '../content/types'
import pressData from '../content/press-quotes.json'

const pressQuotes = pressData as PressQuote[]
---

<section id="press" class="py-20 md:py-32 bg-cream-50">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12">
    <!-- Section Header -->
    <h2 class="text-display text-3xl md:text-4xl text-center mb-6 scroll-reveal">
      Press
    </h2>
    <p class="text-center text-base md:text-lg text-cream-600 mb-12 scroll-reveal">
      What people are saying about <em>Earth Music</em>
    </p>

    <!-- Press Quotes Grid -->
    {pressQuotes.length > 0 ? (
      <div class="grid md:grid-cols-2 gap-6 mb-12 scroll-reveal">
        {pressQuotes.map((quote) => (
          <PressCard
            quote={quote.quote}
            source={quote.source}
            url={quote.url}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-8 scroll-reveal">
        <p class="text-base text-cream-600">
          Press coverage coming soon.
        </p>
      </div>
    )}

    <!-- EPK Download Button -->
    <div class="text-center scroll-reveal">
      <a
        href="/press-kit.pdf"
        download
        class="inline-flex items-center justify-center px-8 py-4 bg-cream-900 text-cream-50 font-medium text-base rounded-sm transition-all duration-200 hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-cream-900 focus-visible:outline-offset-2"
      >
        Download EPK
      </a>
    </div>
  </div>
</section>
