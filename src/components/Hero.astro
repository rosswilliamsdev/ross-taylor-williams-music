---
import { Image } from 'astro:assets'
import albumCover from '../../public/images/album-cover.jpg'
---

<section id="top" class="relative w-full h-screen min-h-[600px] overflow-hidden">
  <!-- Album Cover Background -->
  <div class="absolute inset-0">
    <Image
      src={albumCover}
      alt="Earth Music album cover by Ross Taylor Williams"
      class="w-full h-full object-cover hero-image"
      loading="eager"
      quality={90}
    />
    <!-- Gradient Overlay for Text Legibility -->
    <div class="absolute inset-0 bg-gradient-to-t from-[hsl(25,8%,14%/0.6)] via-transparent to-transparent"></div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 h-full flex flex-col items-center justify-end pb-20 md:pb-24 px-6">
    <h1 class="text-display text-4xl md:text-5xl lg:text-6xl text-cream-50 text-center mb-4 hero-title">
      Ross Taylor Williams
    </h1>
    <p class="text-display text-xl md:text-2xl text-cream-50 mb-8 hero-subtitle">
      Earth Music
    </p>
    <a
      href="#music"
      class="inline-flex items-center justify-center px-8 py-4 bg-sage-500 text-cream-50 font-sans font-medium text-base rounded-sm transition-all duration-200 hover:bg-sage-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-sage-500 focus-visible:outline-offset-2 hero-cta"
    >
      Listen Now
    </a>
  </div>
</section>
