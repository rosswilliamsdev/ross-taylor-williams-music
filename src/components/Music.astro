---
// Music section with Bandcamp embed and streaming links
import { Image } from 'astro:assets';
---

<section id="music" class="py-20 md:py-32 bg-cream-100">
  <div class="max-w-[900px] mx-auto px-6 md:px-12">
    <!-- Section Header -->
    <h2 class="text-display text-3xl md:text-4xl text-center mb-16 scroll-reveal" data-delay="0">
      Listen
    </h2>

    <!-- Album Art + Player + Streaming Links -->
    <div class="max-w-[500px] mx-auto scroll-reveal" data-delay="1">
      <!-- Album Artwork -->
      <div class="mb-8">
        <Image
          src="/images/cover-standing-no-text-optimized.jpeg"
          alt="Earth Music album cover by Ross Taylor Williams"
          width={500}
          height={500}
          class="w-full h-auto rounded-sm shadow-md"
          loading="lazy"
        />
      </div>

      <!-- Bandcamp Player -->
      <div class="mb-8">
        <iframe
          style="border: 0; width: 100%; height: 120px;"
          src="https://bandcamp.com/EmbeddedPlayer/track=3361835868/size=large/bgcol=ffffff/linkcol=7a9475/tracklist=false/artwork=none/transparent=true/"
          seamless
          title="Earth Music by Ross Taylor Williams on Bandcamp"
          loading="lazy"
          class="rounded-sm"
        ></iframe>
      </div>

      <!-- Streaming Links -->
      <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-2 text-sm text-cream-600">
        <a
          href="https://open.spotify.com/artist/4DfAmgwRMNdcbFH6ZR89b2"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 hover:text-sage-500 transition-colors duration-200"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
          </svg>
          <span>Spotify</span>
        </a>

        <span class="text-cream-400" aria-hidden="true">·</span>

        <a
          href="https://music.apple.com/us/artist/ross-taylor-williams/1894977146"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 hover:text-sage-500 transition-colors duration-200"
        >
          <svg class="w-4 h-4" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true">
            <path d="M199 359V199q0-9 10-11l138-28q11-2 12 10v122q0 15-45 20c-57 9-48 105 30 79 30-11 35-40 35-69V88s0-20-17-15l-170 35s-13 2-13 18v203q0 15-45 20c-57 9-48 105 30 79 30-11 35-40 35-69"/>
          </svg>
          <span>Apple Music</span>
        </a>

        <span class="text-cream-400" aria-hidden="true">·</span>

        <a
          href="https://www.youtube.com/channel/UCV-a0e_7ALW6h3OQogXfvIw"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 hover:text-sage-500 transition-colors duration-200"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <span>YouTube</span>
        </a>

        <span class="text-cream-400" aria-hidden="true">·</span>

        <a
          href="https://music.amazon.com/artists/B09VLJFZWV/ross-taylor-williams"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 hover:text-sage-500 transition-colors duration-200"
        >
          <svg class="w-4 h-4" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
            <path d="M26.49,30H5.5A3.35,3.35,0,0,1,3,29a3.35,3.35,0,0,1-1-2.48V5.5A3.35,3.35,0,0,1,3,3,3.35,3.35,0,0,1,5.5,2h21A3.35,3.35,0,0,1,29,3,3.35,3.35,0,0,1,30,5.5v21A3.52,3.52,0,0,1,26.49,30Zm-11-5.79a11.06,11.06,0,0,0,6.74-2.28.51.51,0,0,0,.23-.4.46.46,0,0,0-.51-.49l-.42.12a13.72,13.72,0,0,1-6,1.35,14.45,14.45,0,0,1-7.1-2.44l-.37-.14c-.26,0-.39.13-.4.4a.47.47,0,0,0,.17.34A11.5,11.5,0,0,0,15.47,24.21Zm-1.71-4.58a4.61,4.61,0,0,0,3.55-1.56,3.18,3.18,0,0,0,.58.83c.42.43.71.64.9.64a.73.73,0,0,0,.37-.16,8.39,8.39,0,0,0,.7-.6l.7-.62a.47.47,0,0,0,.23-.33.39.39,0,0,0-.1-.27.26.26,0,0,1-.09-.17,7.25,7.25,0,0,1-.47-.75,23.73,23.73,0,0,1-.22-4.75c0-2.92-1.45-4.38-4.37-4.38C13,7.65,11.5,8.74,11,10.8c0,.29.12.43.34.43l2,.27a1,1,0,0,0,.42-.43A1.67,1.67,0,0,1,15.4,9.76,1.28,1.28,0,0,1,16.84,11l0,1.2q-6.23,0-6.23,4.15a3.16,3.16,0,0,0,.92,2.47A3.21,3.21,0,0,0,13.76,19.63ZM15,17.54A1.35,1.35,0,0,1,13.73,16c0-1.42,1-2.13,3.16-2.13v.62a7.43,7.43,0,0,1,0,1.07,3.1,3.1,0,0,1-.42,1.13,1.64,1.64,0,0,1-1.12.82Zm7.92,5.26c.46,0,.84-.48,1.16-1.41a4.06,4.06,0,0,0,.25-1.32c0-.5-.44-.76-1.31-.76-1.43.11-2.17.42-2.23,1,0,.23.12.34.37.34l1.42-.16c.33,0,.5.08.5.16a2.64,2.64,0,0,1-.18.84c-.11.33-.2.57-.25.71a.94.94,0,0,0-.09.29A.32.32,0,0,0,22.93,22.8Z"/>
          </svg>
          <span>Amazon Music</span>
        </a>

        <span class="text-cream-400" aria-hidden="true">·</span>

        <a
          href="https://rosstaylorwilliams.bandcamp.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 hover:text-sage-500 transition-colors duration-200"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M0 18.75l7.437-13.5H24l-7.438 13.5H0z"/>
          </svg>
          <span>Bandcamp</span>
        </a>
      </div>
    </div>
  </div>
</section>
