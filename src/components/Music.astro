---
// Music section with Bandcamp embed
---

<section id="music" class="py-20 md:py-32 bg-cream-100">
  <div class="max-w-[900px] mx-auto px-6 md:px-12">
    <!-- Section Header -->
    <h2 class="text-display text-3xl md:text-4xl text-bark-500 text-center mb-6 scroll-reveal">
      Earth Music
    </h2>
    <p class="text-center text-base md:text-lg text-cream-600 mb-12 scroll-reveal">
      Listen to the debut album now
    </p>

    <!-- Bandcamp Embed Card -->
    <div class="bg-cream-50 rounded-md shadow-md p-6 md:p-8 scroll-reveal">
      <iframe
        style="border: 0; width: 100%; height: 470px;"
        src="https://bandcamp.com/EmbeddedPlayer/album=ALBUM_ID_PLACEHOLDER/size=large/bgcol=ffffff/linkcol=7ba368/tracklist=false/transparent=true/"
        seamless
        title="Earth Music by Ross Taylor Williams on Bandcamp"
        loading="lazy"
      ></iframe>
      <p class="text-sm text-cream-400 text-center mt-4">
        Also available on <a href="https://open.spotify.com/" target="_blank" rel="noopener noreferrer" class="text-sage-500 hover:underline">Spotify</a>, <a href="https://music.apple.com/" target="_blank" rel="noopener noreferrer" class="text-sage-500 hover:underline">Apple Music</a>, and other streaming platforms.
      </p>
    </div>
  </div>
</section>
