---
interface Props {
  date: string // ISO format: '2026-06-14'
  venue: string
  city: string
  ticketUrl?: string
}

const { date, venue, city, ticketUrl } = Astro.props

// Format date for display
const showDate = new Date(date)
const formattedDate = new Intl.DateTimeFormat('en-US', {
  weekday: 'short',
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).format(showDate)
---

<div class="bg-cream-100 border border-cream-200 rounded-md p-6 shadow-sm hover:shadow-md transition-shadow duration-200">
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div class="flex-1">
      <p class="text-sm font-medium text-sage-500 mb-1">{formattedDate}</p>
      <h3 class="text-display text-xl text-cream-900 mb-1">{venue}</h3>
      <p class="text-sm text-cream-600">{city}</p>
    </div>
    {ticketUrl && (
      <a
        href={ticketUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center px-6 py-2.5 bg-sage-500 text-cream-50 font-medium text-sm rounded-sm transition-all duration-200 hover:bg-sage-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-sage-500 focus-visible:outline-offset-2 md:whitespace-nowrap"
      >
        Get Tickets
      </a>
    )}
  </div>
</div>
